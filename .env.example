# Sanity CMS (Astro client - fetching content at build time)
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-02-01

# Sanity Studio (Studio dev server)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Analytics
PUBLIC_PLAUSIBLE_DOMAIN=greenlock.tech

# Google Tag Manager (dejar vacío para desactivar GTM)
PUBLIC_GTM_ID=GTM-XXXXXXX
