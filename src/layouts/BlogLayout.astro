---
// ============================================================================
// GreenLock Cybersecurity — Blog Post Layout
// Wraps individual blog posts with SEO, JSON-LD BlogPosting, breadcrumbs
// ============================================================================

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/shared/Breadcrumbs.astro';
import type { SanityPost } from '@lib/sanity';

interface Props {
  post: SanityPost;
}

const { post } = Astro.props;

// Breadcrumb items
const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Blog', href: '/recursos/blog' },
  { label: post.title },
];

// JSON-LD BlogPosting schema
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.metaDescription || post.excerpt,
  url: new URL(`/recursos/blog/${post.slug.current}`, Astro.site).href,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: {
    '@type': 'Person',
    name: post.author?.name || 'GreenLock Cybersecurity',
    jobTitle: post.author?.role,
    url: post.author?.linkedin,
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://greenlock.tech/#organization',
    name: 'GreenLock Cybersecurity',
    url: 'https://greenlock.tech',
    logo: {
      '@type': 'ImageObject',
      url: 'https://greenlock.tech/images/icons/Logo.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/recursos/blog/${post.slug.current}`, Astro.site).href,
  },
  inLanguage: 'es',
  isPartOf: {
    '@type': 'Blog',
    name: 'GreenLock Blog',
    url: 'https://greenlock.tech/recursos/blog',
  },
  ...(post.category && { articleSection: post.category }),
  ...(post.tags && post.tags.length > 0 && { keywords: post.tags.join(', ') }),
  ...(post.readTime && {
    timeRequired: `PT${post.readTime.replace(/\D/g, '')}M`,
  }),
  ...(post.featuredImage && {
    image: new URL(post.featuredImage, Astro.site).href,
  }),
};

// JSON-LD BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://greenlock.tech/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://greenlock.tech/recursos/blog/' },
    { '@type': 'ListItem', position: 3, name: post.title, item: new URL(`/recursos/blog/${post.slug.current}/`, Astro.site).href },
  ],
};

// Format published date for display
const formattedDate = new Date(post.publishedAt).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={(post as any).metaTitle || post.title}
  description={post.metaDescription || post.excerpt}
  ogType="article"
  publishedTime={post.publishedAt}
  modifiedTime={post.updatedAt || post.publishedAt}
  author={post.author?.name}
  articleSection={post.category}
  schemas={[blogPostingSchema, breadcrumbSchema]}
>
  <!-- Breadcrumbs -->
  <Breadcrumbs items={breadcrumbItems} />

  <article class="bg-white">
    <div class="container-custom section-padding">
      <div class="max-w-3xl mx-auto">
        <!-- Article Header -->
        <header class="mb-10">
          {post.category && (
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-sm font-medium mb-4">
              {post.category}
            </span>
          )}

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark-900 leading-tight mb-6">
            {post.title}
          </h1>

          {post.excerpt && (
            <p class="text-lg text-dark-500 leading-relaxed mb-6">
              {post.excerpt}
            </p>
          )}

          <!-- Author + Meta -->
          <div class="flex flex-wrap items-center gap-4 text-sm text-dark-400 border-t border-dark-200 pt-6">
            {post.author && (
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-brand-100 flex items-center justify-center">
                  <span class="text-xs font-bold text-brand-600">
                    {post.author.name.split(' ').map(n => n[0]).slice(0, 2).join('')}
                  </span>
                </div>
                <span class="font-medium text-dark-700">{post.author.name}</span>
              </div>
            )}
            <time datetime={post.publishedAt}>{formattedDate}</time>
            {post.readTime && <span>{post.readTime} de lectura</span>}
          </div>
        </header>

        <!-- Article Body (slot for Portable Text content) -->
        <div class="prose prose-lg prose-green max-w-none">
          <slot />
        </div>

        <!-- Tags -->
        {post.tags && post.tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-dark-200">
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-dark-100 text-dark-600 text-sm">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Author Box -->
        {post.author && (
          <div class="mt-10 p-6 bg-dark-50 rounded-xl border border-dark-200">
            <div class="flex items-center gap-5">
              {post.author.image ? (
                <img
                  src={post.author.image}
                  alt={post.author.name}
                  class="w-20 h-20 rounded-full object-cover object-top shrink-0"
                />
              ) : (
                <div class="w-20 h-20 rounded-full bg-brand-100 flex items-center justify-center shrink-0">
                  <span class="text-2xl font-bold text-brand-600">
                    {post.author.name.split(' ').map(n => n[0]).slice(0, 2).join('')}
                  </span>
                </div>
              )}
              <div>
                <p class="font-bold text-dark-900 text-lg">{post.author.name}</p>
                <p class="text-sm text-brand-600 mb-2">{post.author.role}</p>
                {post.author.certifications && post.author.certifications.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {post.author.certifications.map((cert) => (
                      <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-dark-700">
                        {typeof cert === 'object' && cert.icon ? (
                          <img src={cert.icon} alt={typeof cert === 'object' && cert.label ? cert.label : 'Certificación'} class="w-[18px] h-[18px] object-contain rounded" loading="lazy" />
                        ) : null}
                        {typeof cert === 'object' ? cert.label : cert}
                      </span>
                    ))}
                  </div>
                )}
                <div class="flex items-center gap-4">
                  {post.author.linkedin && (
                    <a href={post.author.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-dark-500 hover:text-brand-600 transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                      LinkedIn
                    </a>
                  )}
                  {post.author.youtube && (
                    <a href={post.author.youtube} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-dark-500 hover:text-brand-600 transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                      YouTube
                    </a>
                  )}
                  {post.author.instagram && (
                    <a href={post.author.instagram} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-dark-500 hover:text-brand-600 transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                      Instagram
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        )}

        <!-- CTA -->
        {post.cta && (
          <div class="mt-10 text-center p-8 bg-dark-900 rounded-xl">
            <a
              href={post.cta.href}
              class="inline-flex items-center gap-2 bg-brand-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-brand-600 transition-colors"
            >
              {post.cta.text}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
