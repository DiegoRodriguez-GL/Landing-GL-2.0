---
import BaseLayout from '@layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getSortedPosts } from '@data/blog-posts';

const posts = getSortedPosts();
const [featured, ...rest] = posts;

// Category filters (in order of appearance)
const counts: Record<string, number> = {};
posts.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const categories = Object.keys(counts);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://greenlock.tech/' },
    { '@type': 'ListItem', position: 2, name: 'Blog' },
  ],
};
---

<BaseLayout
  title="Blog de Ciberseguridad"
  description="Artículos técnicos, guías prácticas y análisis del panorama de amenazas. Por profesionales certificados, para profesionales que toman decisiones."
  schemas={[breadcrumbSchema]}
>
  <section class="bg-white">
    <div class="container-custom" style="padding-top: 1.5rem; padding-bottom: 4rem;">

      <!-- Header -->
      <div class="blog-header">
        <h1 class="blog-title">Blog de <span class="text-green-500">ciberseguridad.</span></h1>
        <p class="blog-subtitle">
          Artículos técnicos, guías prácticas y análisis del panorama de amenazas. Por profesionales certificados, para profesionales que toman decisiones.
        </p>
      </div>

      <!-- Category filters -->
      <div class="blog-filters">
        <button class="blog-filter blog-filter--active" data-category="all">
          Todos <span class="blog-filter-count">{posts.length}</span>
        </button>
        {categories.map((cat) => (
          <button class="blog-filter" data-category={cat}>
            {cat} <span class="blog-filter-count">{counts[cat]}</span>
          </button>
        ))}
      </div>

      {featured && (
        <a href={`/recursos/blog/${featured.slug}`} class="blog-hero" data-category={featured.category}>
          <div class="blog-hero-img">
            {featured.image ? (
              <Image src={featured.image} alt={featured.title} width={640} height={360} loading="eager" />
            ) : featured.imageUrl ? (
              <img src={featured.imageUrl} alt={featured.title} width="640" height="360" loading="eager" />
            ) : (
              <div class="blog-hero-placeholder">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
            )}
          </div>
          <div class="blog-hero-content">
            <div class="blog-card-meta">
              <span class="blog-card-cat">{featured.category}</span>
              <span class="blog-card-time">{featured.readTime}</span>
            </div>
            <h2 class="blog-hero-title">{featured.title}</h2>
            <p class="blog-hero-excerpt">{featured.excerpt}</p>
            <div class="blog-card-footer">
              <span class="blog-card-author">{featured.author.name}</span>
              <span class="blog-card-date">{formatDate(featured.publishedAt)}</span>
            </div>
          </div>
        </a>
      )}

      <!-- Posts grid -->
      <div class="blog-grid">
        {rest.map((post) => (
          <a href={`/recursos/blog/${post.slug}`} class="blog-card" data-category={post.category}>
            <div class="blog-card-img">
              {post.image ? (
                <Image src={post.image} alt={post.title} width={400} height={225} loading="lazy" />
              ) : post.imageUrl ? (
                <img src={post.imageUrl} alt={post.title} width="400" height="225" loading="lazy" />
              ) : (
                <div class="blog-card-placeholder">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                </div>
              )}
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-card-cat">{post.category}</span>
                <span class="blog-card-time">{post.readTime}</span>
              </div>
              <h3 class="blog-card-title">{post.title}</h3>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <div class="blog-card-footer">
                <span class="blog-card-author">{post.author.name}</span>
                <span class="blog-card-date">{formatDate(post.publishedAt)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  function initBlogFilters() {
    const filters = document.querySelectorAll<HTMLButtonElement>('.blog-filter');
    const items = document.querySelectorAll<HTMLElement>('[data-category]:not(.blog-filter)');
    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        filters.forEach((b) => b.classList.remove('blog-filter--active'));
        btn.classList.add('blog-filter--active');
        items.forEach((el) => {
          el.style.display = (cat === 'all' || el.dataset.category === cat) ? '' : 'none';
        });
      });
    });
  }
  initBlogFilters();
  document.addEventListener('astro:after-swap', initBlogFilters);
</script>

<style>
  .blog-header { text-align: center; max-width: 48rem; margin: 0 auto 32px; }
  .blog-title { font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 700; color: #111827; margin-bottom: 12px; line-height: 1.15; }
  .blog-subtitle { font-size: 18px; line-height: 1.6; color: #6b7280; }
  .blog-filters { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 40px; }
  .blog-filter { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 6px; border: 1px solid #e5e7eb; background: #fff; color: #6b7280; font-size: 13px; font-weight: 500; cursor: pointer; transition: all .2s; }
  .blog-filter:hover { border-color: #22c55e; color: #111827; }
  .blog-filter--active { background: #22c55e; border-color: #22c55e; color: #fff; }
  .blog-filter-count { font-size: 11px; opacity: .7; }
  .blog-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 16px; overflow: hidden; border: 1px solid #e5e7eb; text-decoration: none; margin-bottom: 32px; transition: border-color .3s, box-shadow .3s; }
  .blog-hero:hover { border-color: #22c55e; box-shadow: 0 8px 30px #00000014; }
  .blog-hero-img { position: relative; overflow: hidden; }
  .blog-hero-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .blog-hero:hover .blog-hero-img img { transform: scale(1.03); }
  .blog-hero-placeholder { width: 100%; height: 100%; min-height: 320px; background: linear-gradient(135deg, #f3f4f6, #e5e7eb); display: flex; align-items: center; justify-content: center; }
  .blog-hero-placeholder svg { width: 48px; height: 48px; color: #d1d5db; }
  .blog-hero-content { padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  .blog-hero-title { font-size: 24px; font-weight: 700; color: #111827; line-height: 1.3; margin-bottom: 12px; transition: color .2s; }
  .blog-hero:hover .blog-hero-title { color: #16a34a; }
  .blog-hero-excerpt { font-size: 15px; line-height: 1.7; color: #6b7280; margin-bottom: 20px; }
  .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-bottom: 48px; }
  .blog-card { display: flex; flex-direction: column; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; text-decoration: none; transition: border-color .3s, box-shadow .3s, transform .3s; }
  .blog-card:hover { border-color: #22c55e; box-shadow: 0 8px 24px #0000000f; transform: translateY(-3px); }
  .blog-card-img { position: relative; overflow: hidden; aspect-ratio: 16 / 9; }
  .blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .blog-card:hover .blog-card-img img { transform: scale(1.05); }
  .blog-card-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #f3f4f6, #e5e7eb); display: flex; align-items: center; justify-content: center; }
  .blog-card-placeholder svg { width: 32px; height: 32px; color: #d1d5db; }
  .blog-card-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
  .blog-card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .blog-card-cat { display: inline-flex; padding: 3px 10px; border-radius: 6px; background: #f0fdf4; color: #111827; border: 1px solid #22c55e; font-size: 12px; font-weight: 600; }
  .blog-card-time { font-size: 12px; color: #9ca3af; }
  .blog-card-title { font-size: 17px; font-weight: 700; color: #111827; line-height: 1.35; margin-bottom: 8px; transition: color .2s; }
  .blog-card:hover .blog-card-title { color: #16a34a; }
  .blog-card-excerpt { font-size: 14px; line-height: 1.6; color: #6b7280; margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .blog-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .blog-card-author { font-size: 13px; font-weight: 500; color: #374151; }
  .blog-card-date { font-size: 12px; color: #9ca3af; }

  @media (max-width: 767px) {
    .blog-hero { grid-template-columns: 1fr; }
    .blog-hero-content { padding: 24px; }
    .blog-hero-title { font-size: 20px; }
    .blog-hero-placeholder { min-height: 200px; }
    .blog-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
