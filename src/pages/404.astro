---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe o ha sido movida."
  noindex={true}
>
  <section class="bg-white">
    <div class="container-custom section-padding">
      <div class="max-w-2xl mx-auto text-center" style="padding-top: 3rem; padding-bottom: 4rem;">

        <p class="err-404-number">404</p>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark-900 mb-5 leading-tight">
          Página <span style="color: #22c55e;">no encontrada.</span>
        </h1>
        <p class="text-lg text-dark-500 leading-relaxed mb-10">
          La ruta que buscas no existe o ha sido movida.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/"
            class="inline-flex items-center justify-center px-8 py-4 rounded-none font-semibold text-base transition-all text-white"
            style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);"
          >
            Ir al inicio
          </a>
          <a
            href="/recursos/blog"
            class="inline-flex items-center justify-center px-8 py-4 rounded-none border-2 border-dark-800 text-dark-800 font-semibold hover:bg-dark-800 hover:text-white transition-colors text-base"
          >
            Ver blog
          </a>
        </div>

      </div>
    </div>
  </section>

<style>
  .err-404-number {
    font-size: clamp(7rem, 20vw, 12rem);
    font-weight: 800;
    line-height: 1;
    color: rgba(34, 197, 94, 0.22);
    margin-bottom: 1rem;
    letter-spacing: -0.04em;
    user-select: none;
  }
</style>
</BaseLayout>
