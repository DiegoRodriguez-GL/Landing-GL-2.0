---
import type { ServiceFAQ } from '@lib/services-data';

interface Props {
  faqs: ServiceFAQ[];
  serviceTitle: string;
}

const { faqs, serviceTitle } = Astro.props;

// JSON-LD FAQPage schema (massive SEO value)
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="section-padding" style="background: #fff;">
  <div class="container-custom">
    <div class="gl-section-head gl-center">
      <span class="gl-eyebrow-mono">FAQ</span>
      <h2 class="gl-section-title">
        Preguntas <span class="gl-hl">frecuentes.</span>
      </h2>
      <p class="gl-section-sub">
        Lo que más nos preguntan sobre {serviceTitle}.
      </p>
    </div>

    <div style="max-width: 820px; margin: 0 auto;">
      {faqs.map((faq) => (
        <details class="gl-faq">
          <summary>
            <span>{faq.question}</span>
            <span class="gl-faq-icon">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </span>
          </summary>
          <div class="gl-faq-body">
            {faq.answer}
          </div>
        </details>
      ))}

      <!-- CTA bajo FAQ -->
      <div style="margin-top: 32px; text-align: center;">
        <p style="font-size: 14px; color: #64748B; margin-bottom: 12px;">
          ¿No encuentras lo que buscas?
        </p>
        <a href="/contacto" style="display: inline-flex; align-items: center; gap: 6px; font-size: 14.5px; font-weight: 600; color: #16a34a; text-decoration: none;">
          Pregúntanos directamente
          <svg style="width: 14px; height: 14px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
