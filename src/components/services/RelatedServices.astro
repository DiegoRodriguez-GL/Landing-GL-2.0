---
import { getRelatedServices } from '@lib/services-data';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const related = getRelatedServices(currentSlug);
---

{related.length > 0 && (
  <section class="section-padding" style="background: #F8FAFC;">
    <div class="container-custom">
      <div class="gl-section-head gl-center">
        <span class="gl-eyebrow-mono">Servicios relacionados</span>
        <h2 class="gl-section-title">
          También puede <span class="gl-hl">interesarte.</span>
        </h2>
      </div>

      <div class="rel-grid">
        {related.map((service) => (
          <a href={`/servicios/${service.slug}`} class="gl-card rel-card">
            <span class={`gl-badge ${service.area === 'cybersecurity' ? 'gl-badge-brand' : 'gl-badge-dark'}`} style="margin-bottom: 16px;">
              {service.area === 'cybersecurity' ? 'Ciberseguridad' : 'Soluciones Digitales'}
            </span>

            <h3>{service.title}</h3>
            <p>{service.description}</p>

            <div class="rel-meta">
              <span><strong>{service.priceFrom}</strong></span>
              <span>·</span>
              <span>{service.duration}</span>
            </div>

            <div class="rel-cta">
              Ver servicio
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .rel-grid {
    display: grid;
    gap: 20px;
    max-width: 1000px;
    margin: 0 auto;
  }
  @media (min-width: 640px) {
    .rel-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .rel-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .rel-card {
    display: flex;
    flex-direction: column;
  }

  .rel-meta {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #F1F5F9;
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 13px;
    color: #64748B;
    font-family: var(--font-mono);
  }
  .rel-meta strong {
    color: #0F172A;
    font-weight: 700;
  }

  .rel-cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: #16a34a;
    transition: gap 0.2s;
  }
  .rel-cta svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s;
  }
  .gl-card:hover .rel-cta svg {
    transform: translateX(4px);
  }
</style>
