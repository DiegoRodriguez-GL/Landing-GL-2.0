---
import type { ServiceData } from '@lib/services-data';

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
---

<section class="gl-hero">
  <div class="container-custom" style="position: relative; z-index: 6;">
    <div class="svc-hero-grid">

      <!-- Left: Content -->
      <div>
        <div class="gl-eyebrow">
          <span class="gl-pulse"></span>
          {service.area === 'cybersecurity' ? 'Ciberseguridad' : 'Soluciones Digitales'} · {service.tagline}
        </div>

        <h1 class="gl-hero-title">
          {service.headline}
        </h1>

        <p class="gl-hero-lead">
          {service.description}
        </p>

        <div class="gl-hero-ctas">
          <a href="/contacto" class="gl-btn-primary">
            {service.ctaText}
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/solicitar-auditoria" class="gl-btn-ghost">
            Auditoría gratuita
          </a>
        </div>

        <!-- Indicators -->
        <div class="svc-hero-meta">
          <div class="svc-hero-meta-item">
            <span class="svc-hero-meta-label">Desde</span>
            <span class="svc-hero-meta-value">{service.priceFrom}</span>
          </div>
          <div class="svc-hero-meta-item">
            <span class="svc-hero-meta-label">Duración</span>
            <span class="svc-hero-meta-value">{service.duration}</span>
          </div>
          {service.certifications.length > 0 && (
            <div class="svc-hero-meta-item">
              <span class="svc-hero-meta-label">Certificaciones</span>
              <div class="svc-hero-certs">
                {service.certifications.map((cert) => (
                  <span class="gl-badge gl-badge-brand">{cert}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Right: Static decorative visual (no widgets/animations) -->
      <div class="svc-hero-visual">
        <div class="svc-hero-card">
          <div class="svc-hero-card-head">
            <div class="svc-hero-card-tag">
              <span class="gl-pulse"></span>
              <span>{service.methodology.framework}</span>
            </div>
          </div>
          <div class="svc-hero-card-body">
            <p class="svc-hero-card-title">Metodología aplicada</p>
            <ul class="svc-hero-steps">
              {service.methodology.steps.slice(0, 4).map((step) => (
                <li>
                  <span class="svc-hero-step-num">{step.step.toString().padStart(2, '0')}</span>
                  <span class="svc-hero-step-text">{step.title}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Corner decorations (exactly like home) -->
  <svg class="gl-hero-corner gl-left" viewBox="0 0 400 400" fill="none">
    <polygon points="0,400 0,160 240,400" fill="#030712" opacity="0.045"/>
    <polygon points="0,400 0,220 180,400" fill="#22c55e" opacity="0.07"/>
    <polygon points="0,400 0,280 120,400" fill="#030712" opacity="0.03"/>
    <line x1="260" y1="400" x2="0" y2="140" stroke="#22c55e" stroke-width="0.75" opacity="0.12"/>
    <line x1="200" y1="400" x2="0" y2="200" stroke="#030712" stroke-width="0.5" opacity="0.06"/>
  </svg>
  <svg class="gl-hero-corner gl-right" viewBox="0 0 400 400" fill="none">
    <polygon points="400,400 400,160 160,400" fill="#030712" opacity="0.045"/>
    <polygon points="400,400 400,220 220,400" fill="#22c55e" opacity="0.07"/>
    <polygon points="400,400 400,280 280,400" fill="#030712" opacity="0.03"/>
    <line x1="140" y1="400" x2="400" y2="140" stroke="#22c55e" stroke-width="0.75" opacity="0.12"/>
    <line x1="200" y1="400" x2="400" y2="200" stroke="#030712" stroke-width="0.5" opacity="0.06"/>
  </svg>
</section>

<style>
  .svc-hero-grid {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .svc-hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 64px;
    }
  }

  .svc-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    margin-top: 8px;
    padding-top: 24px;
    border-top: 1px solid #E2E8F0;
  }
  .svc-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .svc-hero-meta-label {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94A3B8;
    font-weight: 600;
  }
  .svc-hero-meta-value {
    font-size: 16px;
    font-weight: 700;
    color: #0F172A;
    font-family: var(--font-mono);
  }
  .svc-hero-certs {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* Static visual card */
  .svc-hero-visual {
    display: none;
  }
  @media (min-width: 1024px) {
    .svc-hero-visual {
      display: block;
    }
  }
  .svc-hero-card {
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 14px;
    box-shadow: 0 20px 60px -20px rgba(15, 23, 42, 0.2), 0 4px 12px -4px rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }
  .svc-hero-card-head {
    padding: 16px 20px;
    background: #F8FAFC;
    border-bottom: 1px solid #F1F5F9;
  }
  .svc-hero-card-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: #16a34a;
    background: #f0fdf4;
    padding: 5px 10px;
    border-radius: 4px;
  }
  .svc-hero-card-tag .gl-pulse {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: gl-pulse 2s infinite;
  }
  .svc-hero-card-body {
    padding: 24px 20px;
  }
  .svc-hero-card-title {
    font-size: 13px;
    font-weight: 700;
    color: #0F172A;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
    font-family: var(--font-mono);
  }
  .svc-hero-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .svc-hero-steps li {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid #F1F5F9;
  }
  .svc-hero-steps li:last-child { border-bottom: none; }
  .svc-hero-step-num {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: #22c55e;
    flex-shrink: 0;
    width: 24px;
  }
  .svc-hero-step-text {
    font-size: 14px;
    font-weight: 500;
    color: #334155;
  }
</style>
