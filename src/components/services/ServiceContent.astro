---
import type { ServiceData } from '@lib/services-data';

interface Props {
  service: ServiceData;
}

const { service } = Astro.props;
---

<!-- ===== SECTION 1: ¿Qué es? ===== -->
<section class="section-padding" style="background: #F8FAFC;">
  <div class="container-custom">
    <div class="gl-section-head">
      <span class="gl-eyebrow-mono">El servicio</span>
      <h2 class="gl-section-title">
        {service.whatIs.title.split(' ').slice(0, -2).join(' ')} <span class="gl-hl">{service.whatIs.title.split(' ').slice(-2).join(' ')}</span>
      </h2>
    </div>
    <div class="svc-what-grid">
      <div class="svc-what-text">
        {service.whatIs.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <div class="svc-what-side">
        <div class="svc-what-stat">
          <p class="svc-what-stat-num">{service.priceFrom}</p>
          <p class="svc-what-stat-label">Inversión desde</p>
        </div>
        <div class="svc-what-stat">
          <p class="svc-what-stat-num">{service.duration}</p>
          <p class="svc-what-stat-label">Duración estimada</p>
        </div>
        <div class="svc-what-stat">
          <p class="svc-what-stat-num">{service.methodology.framework.split(' ')[0]}</p>
          <p class="svc-what-stat-label">Framework aplicado</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SECTION 2: Entregables (Qué incluye) ===== -->
<section class="section-padding" style="background: #fff;">
  <div class="container-custom">
    <div class="gl-section-head gl-center">
      <span class="gl-eyebrow-mono">Entregables</span>
      <h2 class="gl-section-title">
        Qué incluye <span class="gl-hl">el servicio.</span>
      </h2>
      <p class="gl-section-sub">
        Todo lo que recibes al contratar el servicio. Sin extras, sin sorpresas.
      </p>
    </div>

    <div class="svc-deliv-grid">
      {service.deliverables.map((item) => (
        <div class="gl-card">
          <div class="gl-card-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== SECTION 3: Metodología (timeline horizontal) ===== -->
<section class="section-padding" style="background: #F8FAFC;">
  <div class="container-custom">
    <div class="gl-section-head gl-center">
      <span class="gl-eyebrow-mono">{service.methodology.framework}</span>
      <h2 class="gl-section-title">
        {service.methodology.title.split(' ').slice(0, -2).join(' ')} <span class="gl-hl">{service.methodology.title.split(' ').slice(-2).join(' ')}</span>
      </h2>
      <p class="gl-section-sub">
        Un proceso probado y replicable que aplicamos en cada proyecto.
      </p>
    </div>

    <div class="svc-timeline">
      {service.methodology.steps.map((step, i) => (
        <div class="svc-tl-item">
          <div class="svc-tl-q">
            <span>Fase {step.step.toString().padStart(2, '0')}</span>
          </div>
          <h4>{step.title}</h4>
          <p>{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ---- Qué es ---- */
  .svc-what-grid {
    display: grid;
    gap: 40px;
  }
  @media (min-width: 1024px) {
    .svc-what-grid {
      grid-template-columns: 1.6fr 0.4fr;
      gap: 64px;
      align-items: start;
    }
  }
  .svc-what-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .svc-what-text p {
    font-size: 16.5px;
    color: #475569;
    line-height: 1.7;
    margin: 0;
  }
  .svc-what-side {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .svc-what-stat {
    padding: 24px;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 14px;
  }
  .svc-what-stat-num {
    font-family: var(--font-mono);
    font-size: 26px;
    font-weight: 700;
    color: #16a34a;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 6px 0;
  }
  .svc-what-stat-label {
    font-size: 13px;
    color: #64748B;
    margin: 0;
  }

  /* ---- Deliverables grid ---- */
  .svc-deliv-grid {
    display: grid;
    gap: 20px;
  }
  @media (min-width: 640px) {
    .svc-deliv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .svc-deliv-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ---- Timeline ---- */
  .svc-timeline {
    display: grid;
    gap: 16px;
  }
  @media (min-width: 1024px) {
    .svc-timeline {
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
    }
  }
  .svc-tl-item {
    position: relative;
    padding: 24px;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 14px;
  }
  @media (min-width: 1024px) {
    .svc-tl-item {
      border-radius: 0;
      border-right: none;
      padding: 28px 22px;
    }
    .svc-tl-item:first-child {
      border-top-left-radius: 14px;
      border-bottom-left-radius: 14px;
    }
    .svc-tl-item:last-child {
      border-top-right-radius: 14px;
      border-bottom-right-radius: 14px;
      border-right: 1px solid #E2E8F0;
    }
  }
  .svc-tl-q {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: #16a34a;
    font-weight: 600;
    margin-bottom: 12px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .svc-tl-q::before {
    content: "";
    width: 22px;
    height: 2px;
    background: #22c55e;
  }
  .svc-tl-item h4 {
    font-size: 16px;
    font-weight: 700;
    color: #0F172A;
    margin-bottom: 8px;
    line-height: 1.25;
  }
  .svc-tl-item p {
    font-size: 13.5px;
    color: #64748B;
    line-height: 1.6;
    margin: 0;
  }
</style>
