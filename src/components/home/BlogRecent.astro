---
import { Image } from 'astro:assets';
import { getSortedPosts } from '@data/blog-posts';

// Latest 3 posts (hardcoded data, no CMS)
const posts = getSortedPosts().slice(0, 3).map((p) => ({
  title: p.title,
  excerpt: p.excerpt,
  category: p.category,
  date: p.publishedAt,
  href: `/recursos/blog/${p.slug}`,
  readTime: p.readTime,
  author: p.author.name,
  image: p.image ?? null,
  imageUrl: p.imageUrl ?? '',
}));

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section id="blog" class="bg-white">
  <div class="container-custom section-padding" style="padding-top: 3.5rem;">

    <div class="br-header">
      <div>
        <h2 class="br-title">
          Últimas <span style="color: #22c55e;">publicaciones.</span>
        </h2>
        <p class="br-subtitle">
          Artículos técnicos, guías y análisis del panorama de amenazas por nuestro equipo.
        </p>
      </div>
      <a href="/recursos/blog" class="br-link">
        Ver todas
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="br-grid">
      {posts.map((post) => (
        <a href={post.href} class="br-card">
          <div class="br-card-img">
            {post.image ? (
              <Image src={post.image} alt={post.title} width={400} height={225} loading="lazy" decoding="async" style={post.imageStyle || ''} />
            ) : post.imageUrl ? (
              <img src={post.imageUrl} alt={post.title} width="400" height="225" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;" />
            ) : (
              <div class="br-card-placeholder">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
            )}
          </div>
          <div class="br-card-body">
            <div class="br-card-meta">
              <span class="br-card-cat">{post.category}</span>
              <span class="br-card-time">{post.readTime}</span>
            </div>
            <h3 class="br-card-title">{post.title}</h3>
            <p class="br-card-excerpt">{post.excerpt}</p>
            <div class="br-card-footer">
              <span class="br-card-author">{post.author}</span>
              <span class="br-card-date">{formatDate(post.date)}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .br-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
  }
  .br-title {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    color: #111827;
    margin-bottom: 8px;
    line-height: 1.15;
  }
  .br-subtitle {
    font-size: 18px;
    color: #6b7280;
    line-height: 1.6;
  }
  .br-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 600;
    color: #22c55e;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .br-link:hover { color: #16a34a; }
  .br-link svg { width: 18px; height: 18px; }

  .br-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .br-card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }
  .br-card:hover {
    border-color: #22c55e;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-3px);
  }

  .br-card-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .br-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .br-card:hover .br-card-img img {
    transform: scale(1.05);
  }
  .br-card-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
    display: flex; align-items: center; justify-content: center;
  }
  .br-card-placeholder svg { width: 32px; height: 32px; color: #d1d5db; }

  .br-card-body {
    padding: 20px;
    display: flex; flex-direction: column; flex: 1;
  }

  .br-card-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .br-card-cat {
    display: inline-flex; padding: 3px 10px; border-radius: 6px;
    background: #f0fdf4; color: #111827; border: 1px solid #22c55e; font-size: 12px; font-weight: 600;
  }
  .br-card-time { font-size: 12px; color: #9ca3af; }

  .br-card-title {
    font-size: 17px; font-weight: 700; color: #111827;
    line-height: 1.35; margin-bottom: 8px; transition: color 0.2s;
  }
  .br-card:hover .br-card-title { color: #16a34a; }

  .br-card-excerpt {
    font-size: 14px; line-height: 1.6; color: #6b7280; margin-bottom: 16px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .br-card-footer {
    display: flex; align-items: center; justify-content: space-between; margin-top: auto;
  }
  .br-card-author { font-size: 13px; font-weight: 500; color: #374151; }
  .br-card-date { font-size: 12px; color: #9ca3af; }

  @media (max-width: 1023px) { .br-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 639px) {
    .br-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .br-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
