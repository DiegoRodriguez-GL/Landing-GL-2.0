---
const steps = [
  {
    number: '01',
    title: 'Alcance',
    description: 'Definimos objetivos, perímetro de actuación y reglas de enfrentamiento junto a tu equipo.',
  },
  {
    number: '02',
    title: 'Ejecución',
    description: 'Nuestros auditores simulan ataques reales utilizando metodologías OWASP, PTES y MITRE ATT&CK.',
  },
  {
    number: '03',
    title: 'Informe',
    description: 'Entregamos un informe ejecutivo y técnico con todas las vulnerabilidades, evidencias y severidades.',
  },
  {
    number: '04',
    title: 'Remediación',
    description: 'Acompañamos a tu equipo en la corrección y verificamos que las vulnerabilidades están resueltas.',
  },
];
---

<section class="bg-white">
  <div class="container-custom section-padding">
    <div class="text-center mb-16">
      <p class="text-sm font-mono text-brand-500 tracking-wide uppercase mb-3">
        Metodología
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-dark-900">
        Cómo trabajamos
      </h2>
    </div>

    <!-- Desktop: Horizontal timeline -->
    <div class="hidden md:block">
      <div class="grid grid-cols-4 gap-6 relative">
        <!-- Connecting line -->
        <div class="absolute top-6 left-[12.5%] right-[12.5%] h-0.5 bg-dark-200" aria-hidden="true">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-500 via-brand-400 to-brand-300"></div>
        </div>

        {steps.map((step) => (
          <div class="relative text-center">
            <div class="flex items-center justify-center w-12 h-12 mx-auto rounded-full bg-brand-500 text-white font-bold text-sm relative z-10 shadow-md">
              {step.number}
            </div>
            <h3 class="text-lg font-bold text-dark-900 mt-4 mb-2">
              {step.title}
            </h3>
            <p class="text-sm text-dark-500 leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: Vertical timeline -->
    <div class="md:hidden space-y-8">
      {steps.map((step, index) => (
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-500 text-white font-bold text-sm shrink-0">
              {step.number}
            </div>
            {index < steps.length - 1 && (
              <div class="w-0.5 flex-1 bg-brand-200 mt-2"></div>
            )}
          </div>
          <div class="pb-6">
            <h3 class="text-base font-bold text-dark-900 mb-1">
              {step.title}
            </h3>
            <p class="text-sm text-dark-500 leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
