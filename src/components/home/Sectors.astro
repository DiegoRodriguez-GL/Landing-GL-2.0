---

<section class="bg-dark-50">
  <div class="container-custom section-padding">
    <div class="text-center mb-12">
      <p class="text-sm font-mono text-brand-500 tracking-wide uppercase mb-3">
        Experiencia sectorial
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-dark-900">
        Sectores que protegemos
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
      {sectors.map((sector) => (
        <div
          class="group block p-5 rounded-xl border border-dark-200 bg-white text-center transition-all duration-300"
        >
          <div class="flex items-center justify-center w-12 h-12 mx-auto rounded-lg bg-brand-50 text-brand-500 mb-3 transition-colors">
            <Fragment set:html={sector.icon} />
          </div>
          <h3 class="text-base font-bold text-dark-900 mb-1">
            {sector.title}
          </h3>
          <p class="text-xs text-dark-500 leading-relaxed">
            {sector.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
