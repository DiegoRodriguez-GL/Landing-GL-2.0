---
import { Image } from 'astro:assets';
// Team is always hardcoded — no Sanity dependency
import imgDamian from '@assets/damian.webp';
import imgDiego from '@assets/diego.webp';
import imgCrto from '@assets/crto.webp';
import imgHackNet from '@assets/HackNet-Logo.webp';

const fallbackTeam = [
  {
    name: 'Damián Pérez Moreno',
    role: 'Co-founder & Offensive Security',
    bio: 'Especialista en seguridad ofensiva con experiencia en pentesting web, infraestructura y ejercicios de Red Team para empresas del sector financiero, retail y salud.',
    certifications: [{ icon: imgCrto, label: 'CRTO Certified' }],
    linkedin: 'https://www.linkedin.com/in/dpmcyber/',
    image: imgDamian,
  },
  {
    name: 'Diego Rodríguez Sanz',
    role: 'Co-founder & Security Engineering',
    bio: 'Ingeniero de software y creador de HackNet, canal de YouTube con más de 60.000 suscriptores dedicado a la divulgación de ciberseguridad y hacking ético.',
    certifications: [{ icon: imgHackNet, label: 'HackNet 60.000+ Seguidores' }],
    linkedin: 'https://www.linkedin.com/in/hackn3t/',
    youtube: 'https://www.youtube.com/@hackn3t',
    instagram: 'https://www.instagram.com/hacknetx/',
    image: imgDiego,
  },
];

// Always use hardcoded team — Sanity team members managed via other sections
const team = fallbackTeam;
---

<section id="equipo" class="bg-white">
  <div class="container-custom section-padding" style="padding-bottom: 2rem;">

    <div class="mb-16 max-w-3xl">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark-900 mb-5 leading-tight">
        El equipo detrás de <span style="color: #22c55e;">GreenLock.</span>
      </h2>
      <p class="text-lg text-dark-500 leading-relaxed">
        Profesionales certificados con experiencia real en seguridad ofensiva y defensiva.
      </p>
    </div>

    <div class="team-list">
      {team.map((member, i) => (
        <div class={`team-row ${i % 2 !== 0 ? 'team-row--reverse' : ''}`}>
          <div class="team-photo">
            <Image src={member.image} alt={member.name} width={560} height={560} loading="lazy" decoding="async" />
          </div>
          <div class="team-info">
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-bio">{member.bio}</p>
            <div class="team-certs">
              {member.certifications.map((cert) => (
                <span class="team-cert">
                  {typeof cert === 'object' && cert.icon ? (
                    <Image src={cert.icon} alt={typeof cert === 'object' && cert.label ? cert.label : 'Certificación'} width={18} height={18} class="team-cert-icon" loading="lazy" decoding="async" />
                  ) : null}
                  {typeof cert === 'object' ? cert.label : cert}
                </span>
              ))}
            </div>
            <div class="team-socials">
              <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="team-social-link">
                <svg class="team-social-icon" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
              {member.youtube && (
                <a href={member.youtube} target="_blank" rel="noopener noreferrer" class="team-social-link">
                  <svg class="team-social-icon" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  YouTube
                </a>
              )}
              {member.instagram && (
                <a href={member.instagram} target="_blank" rel="noopener noreferrer" class="team-social-link">
                  <svg class="team-social-icon" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  Instagram
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .team-list {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .team-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: center;
  }

  .team-row--reverse {
    grid-template-columns: 1fr 280px;
  }
  .team-row--reverse .team-photo {
    order: 2;
  }
  .team-row--reverse .team-info {
    order: 1;
  }

  .team-photo img {
    width: 100%;
    max-width: 280px;
    height: 320px;
    object-fit: cover;
    object-position: top;
    border-radius: 16px;
  }

  .team-row .team-photo {
    display: flex;
    justify-content: flex-start;
  }
  .team-row--reverse .team-photo {
    justify-content: flex-end;
  }
  .team-row--reverse .team-photo img {
    height: 340px;
  }

  .team-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .team-name {
    font-size: 32px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .team-role {
    font-size: 17px;
    font-weight: 600;
    color: #16a34a;
    margin-bottom: 16px;
  }

  .team-bio {
    font-size: 16.5px;
    line-height: 1.7;
    color: #6b7280;
    margin-bottom: 20px;
  }

  .team-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .team-cert {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    background: none;
    color: #374151;
    font-size: 14px;
    font-weight: 600;
  }
  .team-cert-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    border-radius: 4px;
  }

  .team-socials {
    display: flex;
    gap: 16px;
  }

  .team-social-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 500;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .team-social-link:hover {
    color: #16a34a;
  }

  .team-social-icon {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 767px) {
    .team-row {
      grid-template-columns: 1fr;
      gap: 24px;
      text-align: center;
    }
    .team-row--reverse .team-photo {
      order: 0;
    }
    .team-row--reverse .team-info {
      order: 0;
    }
    .team-info {
      align-items: center;
    }
    .team-certs {
      justify-content: center;
    }
    .team-row .team-photo,
    .team-row--reverse .team-photo {
      justify-content: center;
    }
    .team-photo img {
      max-width: 220px;
      height: 260px;
    }
    .team-row--reverse .team-photo img {
      height: 260px;
    }
    .team-name {
      font-size: 24px;
    }
    .team-role {
      font-size: 15px;
    }
    .team-bio {
      font-size: 14px;
    }
  }
</style>
