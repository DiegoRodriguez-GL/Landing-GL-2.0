---
import { Image } from 'astro:assets';
import logoImg from '@assets/icons/Logo.webp';

// Anclas a secciones de la propia landing (scroll interno)
const navLinks = [
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Casos', href: '/#casos' },
  { label: 'Equipo', href: '/#equipo' },
  { label: 'Blog', href: '/#blog' },
  { label: 'Contacto', href: '/#contacto' },
];
---

<!-- Announcement Bar -->
<div
  id="announcement-bar"
  style="position: fixed; top: 0; left: 0; right: 0; z-index: 55; background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%); color: #fff; transition: transform 0.3s ease; overflow: hidden;"
>
  <div class="container-custom flex items-center justify-center relative" style="height: 44px;">
    <a
      href="https://wa.me/34682790545?text=Hola%2C%20quiero%20un%20reconocimiento%20de%20huella%20digital%20[REF:WEB-BANNER]"
      target="_blank"
      rel="noopener noreferrer"
      class="announcement-link"
    >
      <span class="announcement-full">Descubre gratis qué saben los hackers de tu empresa</span>
      <span class="announcement-short">¿Tu empresa es segura?</span>
      <span class="announcement-pipe" aria-hidden="true">|</span>
      <span class="announcement-cta">Huella digital gratuita</span>
    </a>
    <button
      id="announcement-close"
      class="announcement-close-btn"
      aria-label="Cerrar anuncio"
    >
      <svg style="width: 16px; height: 16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>

<header
  id="main-header"
  class="fixed left-0 right-0 z-50 transition-all duration-300"
  style="top: 44px;"
  data-transparent
>
  <nav class="container-custom" aria-label="Navegación principal">
    <div class="flex items-center justify-between h-14 lg:h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="GreenLock - Inicio">
        <Image src={logoImg} alt="GreenLock" width={40} height={40} class="w-10 h-10 object-contain" loading="eager" />
        <span class="text-lg font-bold header-logo-text text-dark-900 transition-colors duration-300">
          Green<span class="text-brand-500 header-logo-accent transition-colors duration-300">Lock</span>
        </span>
      </a>

      <!-- Desktop Navigation (anclas a secciones) -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="header-nav-link px-3 py-1.5 text-xs font-medium rounded-md transition-colors uppercase tracking-wider text-dark-700 hover:text-dark-900"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href="https://wa.me/34682790545?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20vuestros%20servicios%20de%20ciberseguridad%20[REF:WEB-NAV]"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center px-4 py-1.5 rounded-md font-semibold text-xs transition-all header-cta-btn"
          style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); border: none; color: #fff;"
        >
          Contáctanos
        </a>

        <!-- Hamburger button -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden flex items-center justify-center w-9 h-9 rounded-lg text-dark-700 hover:bg-dark-100 transition-colors header-hamburger"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-white transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  <!-- Mobile menu top bar -->
  <div class="flex items-center justify-between h-11 px-6 border-b border-dark-100">
    <a href="/" class="flex items-center gap-2" aria-label="GreenLock - Inicio">
      <Image src={logoImg} alt="GreenLock" width={32} height={32} class="w-8 h-8 object-contain" />
      <span class="text-xl font-bold text-dark-900">Green<span class="text-brand-500">Lock</span></span>
    </a>
    <button
      id="mobile-menu-close"
      class="flex items-center justify-center w-10 h-10 rounded-lg text-dark-700 hover:bg-dark-50 transition-colors"
      aria-label="Cerrar menú"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile navigation links -->
  <div class="px-4 py-4 pb-32">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-4 px-2 text-base font-medium border-b border-dark-100 text-dark-900 hover:text-brand-600 transition-colors"
      >
        {link.label}
      </a>
    ))}
  </div>

  <!-- Mobile CTA fixed bottom -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t border-dark-100 lg:hidden">
    <a
      href="https://wa.me/34682790545?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20vuestros%20servicios%20de%20ciberseguridad%20[REF:WEB-MOBILE]"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center w-full px-6 py-3 rounded-lg font-semibold transition-colors text-white"
      style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);"
    >
      Contáctanos
    </a>
  </div>
</div>

<!-- Spacer for non-home pages where header is solid -->
<div id="header-spacer" class="h-24 lg:h-26"></div>

<script>
  function initHeader() {
    const header = document.getElementById('main-header');
    const spacer = document.getElementById('header-spacer');
    const overlayHeroPaths = ['/'];
    const isHome = overlayHeroPaths.includes(window.location.pathname);

    if (!header) return;

    const navLinks = header.querySelectorAll('.header-nav-link');
    const logoText = header.querySelector('.header-logo-text') as HTMLElement | null;
    const logoAccent = header.querySelector('.header-logo-accent') as HTMLElement | null;
    const hamburger = header.querySelector('.header-hamburger') as HTMLElement | null;

    function setSolid() {
      header!.removeAttribute('data-transparent');
      header!.classList.add('bg-white/95', 'backdrop-blur-xl', 'shadow-sm');
      navLinks.forEach(link => {
        link.classList.remove('text-white', 'hover:text-white');
        link.classList.add('text-dark-700', 'hover:text-dark-900');
      });
      if (logoText) { logoText.classList.remove('text-white'); logoText.classList.add('text-dark-900'); }
      if (logoAccent) { logoAccent.classList.remove('text-brand-400'); logoAccent.classList.add('text-brand-500'); }
      if (hamburger) { hamburger.classList.remove('text-white'); hamburger.classList.add('text-dark-700'); }
    }

    if (isHome) {
      if (spacer) spacer.style.display = 'none';
      function onScrollHome() {
        if (window.scrollY > 20) {
          setSolid();
        } else {
          header!.setAttribute('data-transparent', '');
          header!.classList.remove('bg-white/95', 'backdrop-blur-xl', 'shadow-sm');
        }
      }
      window.removeEventListener('scroll', (window as any).__headerScrollFn);
      (window as any).__headerScrollFn = onScrollHome;
      window.addEventListener('scroll', onScrollHome, { passive: true });
      onScrollHome();
    } else {
      if (spacer) spacer.style.display = '';
      if ((window as any).__headerScrollFn) {
        window.removeEventListener('scroll', (window as any).__headerScrollFn);
        (window as any).__headerScrollFn = null;
      }
      setSolid();
    }

    // Announcement bar
    const announcementBar = document.getElementById('announcement-bar');
    const announcementClose = document.getElementById('announcement-close');
    let announcementDismissed = localStorage.getItem('announcement-dismissed') === '1';
    let announcementHidden = false;

    function hideAnnouncement() {
      if (announcementHidden) return;
      announcementHidden = true;
      if (announcementBar) announcementBar.style.transform = 'translateY(-100%)';
      if (header) header.style.top = '0';
    }

    function showAnnouncement() {
      if (!announcementHidden || announcementDismissed) return;
      announcementHidden = false;
      if (announcementBar) announcementBar.style.transform = 'translateY(0)';
      if (header) header.style.top = '44px';
    }

    function dismissAnnouncement() {
      announcementDismissed = true;
      hideAnnouncement();
      localStorage.setItem('announcement-dismissed', '1');
    }

    announcementClose?.addEventListener('click', dismissAnnouncement);

    if (!announcementDismissed) {
      function onScrollAnnounce() {
        if (window.scrollY > 20) { hideAnnouncement(); }
        else { showAnnouncement(); }
      }
      window.removeEventListener('scroll', (window as any).__announceScrollFn);
      (window as any).__announceScrollFn = onScrollAnnounce;
      window.addEventListener('scroll', onScrollAnnounce, { passive: true });
    } else {
      hideAnnouncement();
    }

    // Mobile menu
    const mobileMenu = document.getElementById('mobile-menu');
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const menuClose = document.getElementById('mobile-menu-close');

    function openMenu() {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      menuToggle?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      menuClose?.focus();
    }

    function closeMenu() {
      mobileMenu?.classList.remove('translate-x-0');
      mobileMenu?.classList.add('translate-x-full');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuToggle?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
    mobileMenu?.querySelectorAll('a').forEach((link) => { link.addEventListener('click', closeMenu); });

    // Ensure mobile menu is closed after navigation
    closeMenu();
  }

  // Run on initial load
  initHeader();
  // Re-run after View Transitions swap (client-side navigation)
  document.addEventListener('astro:after-swap', initHeader);
</script>

<!-- Smooth scroll + offset para que las anclas no queden bajo el header fijo -->
<style is:global>
  html { scroll-behavior: smooth; }
  #servicios, #casos, #equipo, #blog, #contacto { scroll-margin-top: 100px; }
</style>

<style>
  .announcement-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 400;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .announcement-link:hover { opacity: 0.85; }
  .announcement-pipe { opacity: 0.6; }
  .announcement-cta {
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .announcement-close-btn {
    position: absolute;
    right: 18px;
    top: 50%;
    transform: translateY(-50%);
    padding: 6px;
    color: rgba(255,255,255,0.7);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  .announcement-close-btn:hover { color: #fff; }
  .announcement-short { display: none; }

  @media (max-width: 640px) {
    .announcement-link {
      font-size: 12px;
      gap: 5px;
      white-space: normal;
    }
    .announcement-full { display: none; }
    .announcement-short { display: inline; }
    .announcement-close-btn { right: 4px; padding: 4px; }
  }
</style>
