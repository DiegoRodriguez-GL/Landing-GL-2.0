---
import { Image } from 'astro:assets';
import logoImg from '@assets/icons/Logo.webp';

const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Secciones',
    links: [
      { label: 'Servicios', href: '/#servicios' },
      { label: 'Casos de éxito', href: '/#casos' },
      { label: 'Equipo', href: '/#equipo' },
      { label: 'Blog', href: '/recursos/blog' },
      { label: 'Contacto', href: '/#contacto' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Aviso legal', href: '/legal/aviso-legal' },
      { label: 'Política de privacidad', href: '/legal/privacidad' },
      { label: 'Política de cookies', href: '/legal/cookies' },
    ],
  },
];
---

<footer class="ft" role="contentinfo">
  <div class="container-custom">

    <!-- Main footer grid -->
    <div class="ft-grid">

      <!-- Brand column -->
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="GreenLock - Inicio">
          <Image src={logoImg} alt="GreenLock" width={32} height={32} class="ft-logo-img" loading="lazy" decoding="async" />
          <span class="ft-logo-text">
            Green<span class="ft-logo-accent">Lock</span>
          </span>
        </a>
        <p class="ft-desc">
          Seguridad ofensiva certificada para empresas que no se pueden permitir fallar.
        </p>
        <div class="ft-contact">
          <a href="mailto:info@greenlock.tech" class="ft-contact-link">
            <svg class="ft-contact-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            info@greenlock.tech
          </a>
          <a href="tel:+34682790545" class="ft-contact-link">
            <svg class="ft-contact-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            +34 682 790 545
          </a>
          <span class="ft-contact-link">
            <svg class="ft-contact-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
            Pedrezuela, Madrid
          </span>
        </div>
      </div>

      <!-- Link columns -->
      {footerLinks.map((column) => (
        <div class="ft-col">
          <h3 class="ft-col-title">{column.title}</h3>
          <ul class="ft-col-list">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="ft-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="ft-bottom">
      <div class="ft-bottom-left">
        <p>&copy; {currentYear} GreenLock Cybersecurity E.S.P.J.</p>
        <p>NIF: E22754246</p>
      </div>

      <!-- Social icons -->
      <div class="ft-socials">
        <a href="https://www.linkedin.com/company/greenlock-cybersecurity" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="ft-social">
          <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.youtube.com/@hackn3t" target="_blank" rel="noopener noreferrer" aria-label="YouTube - HackNet" class="ft-social">
          <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .ft {
    background: #111827;
    color: #fff;
    padding-top: 64px;
    padding-bottom: 0;
  }

  .ft-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
  }

  /* Brand */
  .ft-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    margin-bottom: 16px;
  }
  .ft-logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }
  .ft-logo-text {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
  }
  .ft-logo-accent {
    color: #059669;
  }
  .ft-desc {
    font-size: 14px;
    line-height: 1.7;
    color: #9ca3af;
    margin-bottom: 20px;
    max-width: 300px;
  }
  .ft-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ft-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
  }
  a.ft-contact-link:hover {
    color: #22c55e;
  }
  .ft-contact-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Columns */
  .ft-col-title {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }
  .ft-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ft-link {
    font-size: 14px;
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ft-link:hover {
    color: #22c55e;
  }

  /* Bottom bar */
  .ft-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    border-top: 1px solid #1f2937;
  }
  .ft-bottom-left {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: #6b7280;
  }

  /* Socials */
  .ft-socials {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ft-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: #9ca3af;
    transition: color 0.2s, background 0.2s;
  }
  .ft-social:hover {
    color: #22c55e;
    background: #1f2937;
  }
  .ft-social svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 767px) {
    .ft {
      padding-top: 40px;
    }
    .ft-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-bottom: 32px;
    }
    .ft-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
      padding: 20px 0;
    }
    .ft-bottom-left {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
